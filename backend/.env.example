PORT=5000
MONGODB_URI=mongodb://localhost:27017/exam-platform
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=8h

# Judge0 Configuration
# Option 1: Free public endpoint (no API key needed)
JUDGE0_BASE_URL=https://ce.judge0.com
JUDGE0_API_KEY=
JUDGE0_API_HOST=

# Option 2: RapidAPI (uncomment and fill in)
# JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_API_KEY=your-rapidapi-key
# JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Option 3: Self-hosted (uncomment and fill in)
# JUDGE0_BASE_URL=http://your-vps-ip:2358
# JUDGE0_API_KEY=your-auth-token

BCRYPT_SALT_ROUNDS=12
